# Ваш токен от @BotFather
BOT_TOKEN=123456789:AAH...ваш_длинный_токен...

# Прокси (ОБЯЗАТЕЛЬНО для РФ, иначе будет ошибка подключения)
# Если есть свой прокси, вставьте ссылку сюда. Если нет — оставьте пустым или закомментируйте
PROXY_URL=http://user:pass@proxy:8080

# Настройки
DEBUG=true
LOG_LEVEL=INFO
